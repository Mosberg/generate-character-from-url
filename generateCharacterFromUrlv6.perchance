loadDependencies = {import:ai-character-chat-dependencies-v1} // dexie.js, dompurify, etc.
aiTextPlugin = {import:ai-text-plugin}
superFetch = {import:super-fetch-plugin}
uploadPlugin = {import:upload-plugin}
generatorStats = {import:generator-stats-plugin}

async compressBlobWithGzip(blob) =>
	const compressionStream = new CompressionStream("gzip");
	const compressedStream = blob.stream().pipeThrough(compressionStream);
	let outputBlob = await new Response(compressedStream).blob();
	return new Blob([outputBlob], { type: "application/gzip" });

$meta
	title = Generate Character From URL v6
	description = Adds combined queue export as a single dexie JSON file and global character/advanced settings that are merged into every queued character. Includes scratchpad notes, remembered inputs, and batch processing.
